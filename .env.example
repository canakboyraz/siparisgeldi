# --- Flask ---
SECRET_KEY=degistir-uzun-rastgele-bir-deger

# --- Admin paneli ---
# Bu e-postalarla giriş yapan kullanıcılar /admin panelini görebilir (virgülle ayır)
ADMIN_EMAILS=

# --- Veritabanı ---
# Geliştirme: boş bırak → SQLite (siparis_saas.db)
# Prod: postgresql://kullanici:sifre@host:5432/veritabani
DATABASE_URL=

# --- API credential şifreleme (ZORUNLU) ---
# Üret: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Merkezi Telegram botu ---
# BotFather'dan oluştur (/newbot). Token ve bot kullanıcı adını (@ olmadan) gir.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- Migros Yemek (Gourmet) ---
# Test: https://test.gourmet.migrosonline.com | Canlı: https://gourmet.migrosonline.com
MIGROS_API_BASE=https://gourmet.migrosonline.com
# Secret Key = entegrasyon firması bazında TEK adet (şifreleme). Migros'a webhook
# URL'lerini ilettikten sonra sana verilir. Şimdilik boş bırakabilirsin.
MIGROS_SECRET_KEY=
# Migros webhook'ları Basic Auth ile gelir (firma bazında tek kimlik).
# Migros'a vereceğin kullanıcı/parola. Boşsa doğrulama atlanır.
MIGROS_WEBHOOK_USER=
MIGROS_WEBHOOK_PASS=
#
# Migros'a İLETİLECEK webhook URL'leri (uygulaman yayında olunca):
#   https://<alan-adin>/webhooks/migros/order-created
#   https://<alan-adin>/webhooks/migros/order-canceled
#   https://<alan-adin>/webhooks/migros/delivery-status

# --- WhatsApp (Meta Cloud API) ---
# Meta Business / developers.facebook.com'dan alınır. Kalıcı token için System User kullan.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Meta onaylı utility şablonu (proaktif bildirim için zorunlu)
WHATSAPP_TEMPLATE_NAME=siparis_bildirim
WHATSAPP_TEMPLATE_LANG=tr
# Günlük/haftalık/aylık rapor için AYRI Meta onaylı şablon (3 değişken)
WHATSAPP_REPORT_TEMPLATE_NAME=gunluk_raporr

# --- Ayarlar ---
POLL_INTERVAL_SECONDS=30
# Dev'de 1 (web süreci scheduler'ı çalıştırır). Prod'da 0 yapıp worker.py'yi ayrı çalıştır.
RUN_SCHEDULER=1
